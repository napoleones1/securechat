{
  "name": "securechat-desktop",
  "version": "0.1.0-alpha",
  "description": "SecureChat Desktop Application - Real-time messaging with voice & video calls",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.securechat.app",
    "productName": "SecureChat",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!node_modules/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    }
  },
  "keywords": ["chat", "messaging", "electron", "webrtc", "video-call", "voice-call", "real-time"],
  "author": "Muhamad Haikal <muhamadhaikal.me@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "electron": "^28.1.3",
    "electron-builder": "^24.9.1",
    "electron-reload": "^2.0.0-alpha.1"
  }
}
